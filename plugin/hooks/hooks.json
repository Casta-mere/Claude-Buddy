{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude-buddy/plugin/hooks/react.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude-buddy/plugin/hooks/buddy-comment.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
